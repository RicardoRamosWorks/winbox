[system]
system   =    1:system.drv
sound    =    1:mmsound.drv
comm     =    1:comm.drv

[machine]
ibm_compatible  = "Default Installation",system,kbd,t4s0enha,nomouse,vbeauto,sound,comm,,ebios,new_cookz
all_updates     = "Install With Updates",system,kbd,t4s0enha,nomouse,vbeauto,sound,comm,,ebios,new_cookz

; cookie for updated install and support for modern PCs
[new_cookz]

; fix to allow windows to work with AHCI devices
system.ini,386enh,"device=ahcifix.386",

; win32s device driver
system.ini,386enh,"device=W32S.386",

; WinG & Video for Windows direct video access driver
system.ini,386enh,"device=dva.386",

; intel fpu fix
system.ini,386enh,"device=fp.386",
system.ini,MathCoprocessor,"FPUFlags=1",

; fixes most issues with large ammounts of memory
system.ini,386enh,"PageOverCommit=1",
system.ini,386enh,"MaxPhysPage=40000",

; runs the display profiler on first boot and removes entry from win.ini
win.ini,windows,"run=profdisp.exe runonce.bat",

; needed to supress win32s out of date error even though they aren't
win.ini,windows,"load=rundll32.exe",

