   rasadmin.hlp
   rasadmin.ico
   rasphone.msg
   rasdial.exe
   rashelp.msg
   rasload.bat
   rashelp.exe
   rasconf.hlp
   rasphone.ico
   modems.inf
   comdev.ini
   ; Various names for old Windows SETUP.EXE
   SETUP.EXE
   INSTALL.EXE
   ASETTA.EXE
   CONFIG.EXE
   INSTALAR.EXE
   KURMA.EXE
   WINSETUP.EXE

